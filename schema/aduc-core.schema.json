{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aduc.example/schema/0.1/aduc-core.schema.json",
  "title": "AI Data Understanding Core Contract 0.1",
  "description": "Official experimental modular Draft 2020-12 schema for the frozen ADUC Core object model.",
  "$defs": {
    "aduc": {
      "type": "object",
      "properties": {
        "contractId": {"$ref": "aduc-metadata.schema.json#/$defs/iri"},
        "coreVersion": {"$ref": "aduc-metadata.schema.json#/$defs/semver"},
        "modelVersion": {"const": "0.1.0"},
        "status": {"enum": ["draft", "inferred", "reviewed", "verified", "canonical", "deprecated"]},
        "createdAt": {"$ref": "aduc-metadata.schema.json#/$defs/timestamp"},
        "publisher": {"$ref": "aduc-metadata.schema.json#/$defs/iri"},
        "conformsTo": {"$ref": "aduc-metadata.schema.json#/$defs/iriArray"},
        "supersedes": {"$ref": "aduc-metadata.schema.json#/$defs/iri"},
        "extensionDeclarations": {
          "type": "array",
          "items": {"$ref": "extension.schema.json#/$defs/extensionDeclaration"},
          "uniqueItems": true
        }
      },
      "required": ["contractId", "coreVersion", "modelVersion", "status", "createdAt", "publisher", "conformsTo"],
      "additionalProperties": false
    }
  },
  "$ref": "aduc-envelope.schema.json"
}

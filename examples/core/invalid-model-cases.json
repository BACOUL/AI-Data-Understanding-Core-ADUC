      "patch": [["set", ["aduc", "supersedes"], "urn:aduc:contract:river-r42:2026-07-14"]],
      "code": "ADUC-CORE-VERSION-001"
    },
    {
      "id": "hidden-provider-field",
      "patch": [["set", ["semantics", "consumerPrompt"], "Use private model memory"]],
      "code": "ADUC-CORE-HIDDEN-001"
    },
    {
      "id": "policy-without-provenance-module",
      "patch": [["remove", ["provenance"]]],
      "code": "ADUC-CORE-DEPENDENCY-001"
    }

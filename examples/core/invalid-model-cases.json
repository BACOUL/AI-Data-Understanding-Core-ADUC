      "code": "ADUC-CORE-ID-002"
    },
    {
      "id": "unresolved-cross-module-reference",
      "patch": [["set", ["semantics", "assertions", 0, "subjectRef"], "urn:example:field:missing"]],
      "code": "ADUC-CORE-REF-001"
    },
    {
      "id": "structure-bound-to-wrong-resource",
      "patch": [["set", ["structure", "resourceRef"], "urn:example:resource:other"]],
      "code": "ADUC-CORE-REF-002"
    },
    {
      "id": "resource-duplicates-producer",
      "patch": [["set", ["resource", "producer"], "urn:example:agent:river-agency"]],

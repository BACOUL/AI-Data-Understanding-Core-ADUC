        ["set", ["identity", "identityAssertions", 0, "identityRelationIri"], "http://www.w3.org/2004/02/skos/core#closeMatch"],
        ["set", ["identity", "identityAssertions", 0, "decision"], "exactEntity"]
      ],
      "code": "ADUC-CORE-IDENTITY-001"
    },
    {
      "id": "relation-predicate-from-label",
      "patch": [["set", ["relations", 0, "predicateIri"], "derived from"]],
      "code": "ADUC-CORE-IRI-001"
    },
    {
      "id": "classification-made-executable",
      "patch": [
        ["set", ["policy", "policies", 0, "rules", 0, "effect"], "classification"],
        ["set", ["policy", "policies", 0, "rules", 0, "machineEvaluable"], true]
      ],
      "code": "ADUC-CORE-POLICY-001"
    },
    {
      "id": "undeclared-extension-namespace",
      "patch": [["set", ["semantics", "extensions", "https://unknown.example/ext/"], {"value": 1}]],
      "code": "ADUC-CORE-EXT-001"

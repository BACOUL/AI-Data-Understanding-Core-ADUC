    },
    {
      "id": "missing-resource-block",
      "patch": [["remove", ["resource"]]],
      "code": "ADUC-CORE-ENVELOPE-001"
    },
    {
      "id": "missing-structure-block",
      "patch": [["remove", ["structure"]]],
      "code": "ADUC-CORE-ENVELOPE-001"
    },
    {
      "id": "unknown-top-level-block",
